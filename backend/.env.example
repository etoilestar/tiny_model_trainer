SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-change-in-production
DATABASE_URL=sqlite:///trainer.db

# Redis 连接配置（使用本机已有的 Redis）
# 格式：redis://[:密码@]主机:端口/数据库编号
# 示例（本机无密码）：REDIS_URL=redis://127.0.0.1:6379/0
# 示例（本机有密码）：REDIS_URL=redis://:yourpassword@127.0.0.1:6379/0
# 示例（远程 Redis）：REDIS_URL=redis://192.168.1.100:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

UPLOAD_FOLDER=./uploads
MODEL_FOLDER=./models
CHECKPOINT_FOLDER=./checkpoints
FLASK_ENV=development
